# Variables d'environnement — MCT IT Portal Backend
# Copier ce fichier en .env et remplir les valeurs

# Serveur
PORT=3001
NODE_ENV=development

# Base de données PostgreSQL
DATABASE_URL="postgresql://postgres:password@localhost:5432/mct_it_portal"

# JWT
JWT_SECRET=change_this_to_a_very_long_random_secret_string_in_production
JWT_EXPIRES_IN=8h

# Email SMTP MCT
SMTP_HOST=smtp.mct.ci
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=noreply@mct.ci
SMTP_PASS=your_smtp_password
EMAIL_FROM="MCT IT Portal <noreply@mct.ci>"

# URL du frontend (pour les liens dans les emails)
FRONTEND_URL=http://localhost:5173
